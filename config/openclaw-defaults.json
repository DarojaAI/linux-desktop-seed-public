{
  "$schema": "https://docs.openclaw.ai/schema.json",
  "meta": {
    "lastTouchedVersion": "2026.04.11",
    "lastTouchedAt": "2026-04-25T00:00:00Z"
  },
  "auth": {
    "profiles": {
      "openrouter:default": {
        "provider": "openrouter",
        "mode": "api_key"
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "openrouter": {
        "baseUrl": "https://openrouter.ai/api/v1",
        "apiKey": "${OPENROUTER_API_KEY}",
        "api": "openai-completions",
        "injectNumCtxForOpenAICompat": true,
        "headers": {
          "HTTP-Referer": "https://github.com/patelmm79/ubuntu-8gb-hel1-1",
          "X-Title": "ubuntu-8gb-hel1-1"
        },
        "models": [
          {
            "id": "minimax/MiniMax-M2.7",
            "name": "MiniMax-M2.7",
            "api": "openai-completions",
            "reasoning": true,
            "input": ["text", "image"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 100000,
            "maxTokens": 8192
          },
          {
            "id": "anthropic/claude-haiku-4-5",
            "name": "Claude Haiku",
            "api": "openai-completions",
            "reasoning": false,
            "input": ["text", "image"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 200000,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": "openrouter/minimax/MiniMax-M2.7",
      "thinkingDefault": "minimal",
      "compaction": {
        "mode": "default",
        "reserveTokens": 20000,
        "keepRecentTokens": 4000,
        "reserveTokensFloor": 20000,
        "maxHistoryShare": 0.03
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 4
      },
      "costLimits": {
        "perRequestUSD": 0.10,
        "perHourUSD": 2.00,
        "perDayUSD": 10.00,
        "action": "pause"
      },
      "rateLimit": {
        "requestsPerMinute": 20,
        "tokensPerMinute": 100000
      },
      "timeout": {
        "responseSeconds": 120,
        "fallbackModel": "openrouter/openai/gpt-4o-mini"
      },
      "fallback": {
        "onError": "openrouter/openai/gpt-4o-mini",
        "onTimeout": "openrouter/openai/gpt-4o-mini",
        "onCostLimit": "pause",
        "maxFallbackAttempts": 2
      },
      "systemPrompt": "config/mental-seal-prompt.txt"
    }
  },
  "messages": {
    "ackReactionScope": "all"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "channels": {
    "discord": {
      "enabled": true,
      "token": "${DISCORD_BOT_TOKEN}",
      "groupPolicy": "allowlist",
      "streaming": { "mode": "off" },
      "allowFrom": [],
      "guilds": {}
    }
  },
  "gateway": {
    "mode": "local"
  },
  "audit": {
    "enabled": true,
    "logFile": "/var/log/openclaw/audit.log",
    "logLevel": "info",
    "events": ["message.received", "message.sent", "agent.start", "agent.complete", "agent.error", "tool.call", "cost.limit.hit", "auth.denied"],
    "rotation": { "maxSizeMB": 50, "keepDays": 30 }
  }
}